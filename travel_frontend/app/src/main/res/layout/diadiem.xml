<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fillViewport="true"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/rounded_white_redborder_bg"
        android:padding="15dp">

        <!-- Top Image -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="200dp">

            <Button
                android:id="@+id/btn_make_plans"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="top|end"
                android:textColor="@android:color/white"
                android:background="@drawable/round_white_opaque_button"
                android:text="X" />

            <!-- Tag / Badge overlay -->

            <ImageView
                android:id="@+id/image_header"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/sample_image" />

            <LinearLayout
                android:layout_width="130dp"
                android:padding="0dp"
                android:layout_height="20dp"
                android:layout_gravity="bottom|start"
                android:background="@drawable/rounded_pink_bg">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="match_parent"
                    android:layout_margin="2dp"
                    android:padding="10dp">

                </ImageView>
                <TextView
                    android:id="@+id/tag_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="2dp"
                    android:padding="0dp"
                    android:text="LỄ HỘI VĂN HÓA"
                    android:textColor="#c6102e"
                    android:textSize="12sp"
                    />

            </LinearLayout>

        </FrameLayout>

        <!-- Name -->
        <TextView
            android:id="@+id/area_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Vịnh Hạ Long"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:layout_marginTop="8dp" />

        <!-- Location -->
        <TextView
            android:id="@+id/area_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quảng Ninh, Việt Nam"
            android:textSize="14sp"
            android:textColor="#c6102e"
            android:layout_marginTop="4dp" />

        <!-- Description -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="150dp">
            <TextView
                android:id="@+id/area_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Vịnh Hạ Long, nằm tại tỉnh Quảng Ninh, là di sản thiên nhiên thế giới nổi tiếng với cảnh quan kỳ vĩ gồm hàng nghìn đảo đá vôi và hang động độc đáo trên mặt biển xanh ngọc. Được UNESCO công nhận và là một trong 7 kỳ quan thiên nhiên mới của thế giới, đây là điểm đến không thể bỏ qua tại Việt Nam, đặc biệt từ tháng 3 đến tháng 8"
                android:textSize="14sp"
                android:layout_marginTop="10dp"/>

        </ScrollView>

        <!-- Landmark / Tour Boxes -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:id="@+id/landmark_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:spacing="8dp"></LinearLayout>
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btn_make_plans"
                android:layout_width="350dp"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:background="@drawable/rounded_deepred_bg"
                android:text="Make Plans" />

            <Button
                android:id="@+id/btn_close"
                android:layout_width="350dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="0dp"
                android:layout_marginTop="10dp"
                android:textColor="#c6102e"
                android:background="@drawable/rounded_white_redborder_bg"
                android:text="Close" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>