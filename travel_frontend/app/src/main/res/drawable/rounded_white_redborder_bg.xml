<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background color -->
    <solid android:color="#FFF"/> <!-- reddish pink -->

    <!-- Rounded corners -->
    <corners android:radius="20dp"/>

    <!-- Optional padding inside -->
    <padding
        android:left="12dp"
        android:top="8dp"
        android:right="12dp"
        android:bottom="8dp"/>
    <!-- Border / stroke -->
    <stroke
        android:width="3dp"
        android:color="#FFA59A"/>

</shape>